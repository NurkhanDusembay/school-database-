HOST=127.0.0.1
PORT=3000
PGHOST=localhost
PGPORT=5432
PGDATABASE=school_system
PGUSER=postgres
PGPASSWORD=your_password_here
DATABASE_SSL=false

# You can also use a single connection string instead:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/school_system

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# Email (SMTP) — used for 2FA codes
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=School Academic <you@gmail.com>
